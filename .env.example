# CMC Configuration
# The CMC URL follows the pattern: https://{cluster_name}.cloudstaging.incortalabs.com/cmc
# The Cloud Portal cluster name is auto-inferred from the subdomain.
CMC_URL=https://your-cluster.cloudstaging.incortalabs.com/cmc
CMC_USER=admin
CMC_PASSWORD=your-password
CMC_CLUSTER_NAME=customCluster

# SSL Verification (optional, defaults to true)
VERIFY_SSL=true

# Qdrant Vector Database (for knowledge base search)
QDRANT_URL=
QDRANT_API_KEY=

# Incorta Configuration (for Zendesk/Jira queries)
INCORTA_ENV_URL=https://your-incorta-env.com/incorta
INCORTA_TENANT=your-tenant
INCORTA_USERNAME=your-username
INCORTA_PASSWORD=your-password
INCORTA_SQLX_HOST=jdbc:hive2://your-sqlx-host:443/;transportMode=http;httpPath=your-path/cliservice;ssl=true

# Cloud Portal Configuration
# Uses the user-facing Cloud Portal (cloudstaging) for cluster metadata.
#
# AUTO-INFERRED (no configuration needed):
#   - Cluster name: extracted from CMC_URL subdomain (e.g., habibascluster)
#   - Token: obtained via browser OAuth login, cached at ~/.incorta_cloud_token.json
#   - User ID: extracted from JWT token after login
#
# First-time setup: run `python scripts/cloud_login.py` to authenticate.
# After that, tokens auto-refresh silently via refresh tokens.
#
# Optional overrides (only if auto-inference doesn't work):
# CLOUD_PORTAL_CLUSTER_NAME=habibascluster
# CLOUD_PORTAL_URL=https://cloudstaging.incortalabs.com
# CLOUD_PORTAL_TOKEN=            # Static token for Docker/headless
# CLOUD_PORTAL_REFRESH_TOKEN=    # For auto-renewal in headless environments
# CLOUD_PORTAL_USER_ID=          # User UUID from JWT (auto-extracted after login)
#
# Auth0 overrides (defaults work for staging Cloud Portal):
# AUTH0_DOMAIN=auth-staging.incortalabs.com
# AUTH0_CLIENT_ID=1H6oWlDKORKc6BmiYWSjECS8Zq6XesV8
# AUTH0_AUDIENCE=https://cloud.server/api/
# AUTH0_CALLBACK_PORT=8910

# Remote deployment (optional)
# If set, used as the MCP server's public URL for OAuth callbacks.
# The /callback endpoint will be registered as the Auth0 redirect URI.
# If not set, auto-detected from cloudflared metrics API, then falls back to localhost.
# MCP_PUBLIC_URL=https://your-tunnel-url.trycloudflare.com

# Cloudflared metrics host (for auto-detecting tunnel URL)
# Default: http://localhost:2000
# CLOUDFLARED_METRICS_HOST=http://localhost:2000

# Docker/Headless mode (auto-detected, but can be forced):
# HEADLESS=true

# Token cache path (for Docker volume mounts):
# TOKEN_CACHE_PATH=/data/.incorta_cloud_token.json
