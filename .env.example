# =============================================================================
# Incorta Upgrade Assistant — Server Environment Configuration
# =============================================================================
# These are SERVER-SIDE settings. User credentials (CMC, Analytics) are passed
# per-request as HTTP headers from the MCP client — they do NOT go here.
# =============================================================================

# Public URL of this server (used for OAuth /callback redirect URI)
# Must match the domain registered in Auth0
MCP_PUBLIC_URL=https://7196.devopsportal.incortaops.com

# Server bind settings (defaults shown)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Qdrant Vector Database (for knowledge base search)
# These are shared server credentials — all users share the same knowledge base
QDRANT_URL=https://2a5d5a1c-e40f-476e-9aeb-3c96bc8c5b22.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Incorta Analytics (for Zendesk/Jira SQL queries)
# These are shared internal Incorta credentials for querying support data
INCORTA_ENV_URL=https://your-incorta-env.com/incorta
INCORTA_TENANT=your-tenant
INCORTA_USERNAME=your-username
INCORTA_PASSWORD=your-password

# Directory for per-user Cloud Portal JWT files
# Each user's token is stored as data/tokens/{email}.json
TOKENS_DIR=/app/data/tokens

# SSL verification (set to false only for local dev with self-signed certs)
VERIFY_SSL=true

# Auth0 overrides (auto-selected per environment from CMC URL, rarely needed)
# Staging defaults:  AUTH0_CLIENT_ID=0jXCrcpFe6PDm6sIMxDi7hunFCWeRLpt
#                    AUTH0_DOMAIN=auth-staging.incortalabs.com
# Production:        AUTH0_CLIENT_ID=<ask cloud team>
#                    AUTH0_DOMAIN=auth.incorta.com
# AUTH0_CLIENT_ID=
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=https://cloud.server/api/
