# =============================================================================
# Incorta Upgrade Assistant — Server Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before deploying.
#
# These are SERVER-SIDE settings. User credentials (CMC, Analytics) are passed
# per-request as HTTP headers from the MCP client — they do NOT go here.
# =============================================================================

# Public URL of this server (used for OAuth /callback redirect URI)
# Must match the domain registered in Auth0 Allowed Callback URLs
MCP_PUBLIC_URL=https://your-server-domain.example.com

# Server bind settings (defaults shown, usually no need to change)
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ---------------------------------------------------------------------------
# Qdrant Vector Database (for knowledge base search)
# Shared server credentials — all users share the same knowledge base index
# ---------------------------------------------------------------------------
QDRANT_URL=https://<your-qdrant-cluster>.cloud.qdrant.io:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# ---------------------------------------------------------------------------
# Internal Incorta instance (for Zendesk support ticket & Jira bug queries)
#
# This is NOT the customer's cluster — it is Incorta's own internal analytics
# instance that contains the ZendeskTickets and Jira_F schemas.
#
# IMPORTANT: The account used here must have READ access to both:
#   - ZendeskTickets schema (tables: ticket, ticket_tags, Upgrade_tickets, etc.)
#   - Jira_F schema (tables: Issues, IssueFixVersions, IssueAffectedVersions, etc.)
#
# Without this access the Zendesk/Jira tools will return login errors.
# ---------------------------------------------------------------------------
INCORTA_ENV_URL=https://<internal-incorta-host>/incorta
INCORTA_TENANT=<tenant-name>
INCORTA_USERNAME=<username-with-zendesk-jira-schema-access>@incorta.com
INCORTA_PASSWORD=<password>

# Directory for per-user Cloud Portal JWT files (default shown)
# Each user's token is stored as data/tokens/{email}.json
TOKENS_DIR=/app/data/tokens

# SSL verification (set to false only for local dev with self-signed certs)
VERIFY_SSL=true

# ---------------------------------------------------------------------------
# Auth0 Configuration (auto-selected per environment from CMC URL)
# Only override these if you need to force a specific Auth0 app
# ---------------------------------------------------------------------------
# Staging defaults:  AUTH0_CLIENT_ID=<staging-client-id>
#                    AUTH0_DOMAIN=auth-staging.incortalabs.com
# Production:        AUTH0_CLIENT_ID=<prod-client-id>
#                    AUTH0_DOMAIN=auth.incorta.com
# AUTH0_CLIENT_ID=
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=https://cloud.server/api/
